static uint32_t count_items(Buf *b) {
    DWORD o = 0;
    uint32_t c = 0;

    while (o + 32 <= b->n && !z32(b->p + o)) {
        if (o + 36 > b->n)
            break;

        uint32_t span = u32(b->p + o + 32);

        if (span < 4 || o + 32 + span > b->n)
            break;

        c++;
        o += 32 + span;
    }

    return c;
