static int itempos(Buf *b, uint32_t idx, DWORD *po, DWORD *pn) {
    DWORD o = 0;
    uint32_t c = 0;

    while (o + 32 <= b->n && !z32(b->p + o)) {
        if (o + 36 > b->n)
