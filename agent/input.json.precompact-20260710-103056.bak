rics.height;\\n        }\\n    }\\n    if (layout) layout->Release();\\n    if (fmt) fmt->Release();\\n    free(ws);\\n    return SUCCEEDED(hr);\\n}\\n\\n'''\\nif needle not in t:raise SystemExit('draw needle missing')\\nt=t.replace(needle,impl+needle)\\np.write_text(t,encoding='utf8')\\n\\n# Replace compact render source with formatted equivalent and measured hit boxes.\\np=root/'mods_src/ui_render.c';t=p.read_text(encoding='utf8')\\nt=t.replace('static void txt(int x,int y,u32 c,float z,const char*s){dxgfx_draw_text(x,y,c,z,s,(u32)strlen(s));}',\\n'''static void txt(int x,int y,u32 c,float z,const char*s){dxgfx_draw_text(x,y,c,z,s,(u32)strlen(s));}\\nstatic float text_width(float size,const char*s){float m[2]={0,0};if(!dxgfx_measure_text(size,s,(u32)strlen(s),m))return 0;return m[0];}''')\\nt=t.replace('''txt((int)x,(int)y-28,0xff9da7b3,16,title);if(mx>=x&&mx<x+520&&my>=y-32&&my<y&&press&2)''','''txt((int)x,(int)y-28,0xff9da7b3,16,title);float title_w=text_width(16,title);if(mx>=x&&mx<x+title_w&&my>=y-32&&my<y&&press&2)''')\\nt=t.replace('''const char*nm=name(s,b+o);float w=170;if(mx>=x&&mx<x+520&&my>=ry&&my<ry+24)''','''const char*nm=name(s,b+o);float token_w=text_width(17,nm);if(mx>=x&&mx<x+token_w&&my>=ry&&my<ry+24)''')\\nt=t.replace('''if(mx>=x&&mx<x+100&&my>=ry&&my<ry+24&&(press&1))''','''float end_w=text_width(16,\\\"<end>\\\");if(mx>=x&&mx<x+end_w&&my>=ry&&my<ry+24&&(press&1))''')\\np.write_text(t,encoding='utf8')\\nprint('measurement API and exact hit regions applied')\"}"
