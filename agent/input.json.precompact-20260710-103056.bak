        "content": "\n### mods_src/ui_render.c\n#include <windows.h>\n#include <stdio.h>\n#include <string.h>\ntypedef unsigned char u8;typedef unsigned u32;typedef u8 H[32];\nextern __declspec(dllimport) void cont(void);extern __declspec(dllimport) int cvm_resolve_payload_hash(const H,H);extern __declspec(dllimport) u8*cvm_cached_base(void);extern __declspec(dllimport) u32 cvm_cached_len(void);\n#include \"../uistate.h\"\n#include \"../dxgfx.h\"\nstatic int zero(u8*p){for(int i=0;i<32;i++)if(p[i])return 0;return 1;}static int same(H a,H b){return !memcmp(a,b,32);}static u32 sz(u8*p){return 36+*(u32*)(p+32);}static int valid(u8*b,u32 n,u32 o){return o+36<=n&&!zero(b+o)&&o+sz(b+o)<=n;}\nstatic const char*name(UiState*s,H h){for(u32 i=0;i<s->reg_count;i++)if(!s->reg[i].tag&&same(s->reg[i].token,h))return s->reg[i].name;static char x[12];snprintf(x,sizeof(x),\"%02x%02x%02x%02x\",h[0],h[1],h[2],h[3]);return x;}\nstatic void txt(int x,int y,u32 c,float z,const char*s){dxgfx_draw_text(x,y,c,z,s,(u32)strlen(s));}\nstatic void view(UiState*s,u32 vi,float mx,float my,int press){UiView*v=&s->views[vi];H h;cvm_resolve_payload_hash(v->key,h);u8*b=cvm_cached_base();u32 n=cvm_cached_len();float x=v->x,y=v->y;if(v->linked&&v->parent>=0&&(u32)v->parent<s->view_count)dxgfx_draw_line(s->views[v->parent].x+v->link_x,s->views[v->parent].y+v->link_y,x,y,0xff62c982,2);char title[80];snprintf(title,sizeof(title),\"[%u] %02x%02x%02x%02x\",vi,v->key[0],v->key[1],v->key[2],v->key[3]);txt((int)x,(int)y-28,0xff9da7b3,16,title);if(mx>=x&&mx<x+520&&my>=y-32&&my<y&&press&2){s->active_view=vi;s->dragging_view=(int)vi;}u32 o=0;float ry=y;while(valid(b,n,o)){const char*nm=name(s,b+o);float w=170;if(mx>=x&&mx<x+520&&my>=ry&&my<ry+24){if(press&1){s->active_view=vi;s->point_off=o;}if(press&2&&s->view_count<UI_MAX_VIEWS){UiView*nv=&s->views[s->view_count];memset(nv,0,sizeof(*nv));nv->used=1;memcpy(nv->key,b+o,32);nv->x=mx;nv->y=my;nv->linked=1;nv->parent=(int)vi;nv->link_x=80;nv->link_y=ry-y+10;s->active_view=s->view_count;s->dragging_view=(int)s->view_count;s->view_count++;}}if(vi==s->active_view&&o==s->point_off)dxgfx_draw_rect(x-7,ry-2,510,23,0xff34414d,1,1);txt((int)x,(int)ry,0xffe8ecef,17,nm);u32 pn=*(u32*)(b+o+32);if(pn){char q[100];int printable=1;u32 z=pn<42?pn:42;for(u32 j=0;j<z;j++)if(b[o+36+j]<32||b[o+36+j]>126)printable=0;if(printable)snprintf(q,sizeof(q),\"'%.*s'\",(int)z,b+o+36);else snprintf(q,sizeof(q),\"[%u bytes]\",pn);txt((int)x+190,(int)ry,0xff7fb8d8,15,q);}ry+=24;o+=sz(b+o);}if(mx>=x&&mx<x+100&&my>=ry&&my<ry+24&&(press&1)){s->active_view=vi;s->point_off=o;}if(vi==s->active_view&&o==s->point_off)dxgfx_draw_rect(x-7,ry-2,90,23,0xff34414d,1,1);txt((int)x,(int)ry,0xff66717d,16,\"<end>\");}\n__declspec(dllexport) void run(void){UiState*s=ui_state();int*m=s->mouse;float*wm=s->world_mouse;dxgfx_set_camera(s->cam_x,s->cam_y,s->zoom);dxgfx_world_mouse(wm);for(u32 i=0;i<s->view_count;i++)if(s->views[i].used)view(s,i,wm[0],wm[1],m[3]);dxgfx_set_camera(640,360,1);char hud[420];snprintf(hud,sizeof(hud),\"%s%s%s\",s->input,s->completion,s->dirty?\" *\":\"\");dxgfx_draw_rect(12,12,520,30,0xdd171b1f,1,1);txt(20,17,0xffffffff,17,hud);char status[100];snprintf(status,sizeof(status),\"%u commands  view %u/%u\",s->reg_count,s->active_view+1,s->view_count);txt(20,48,0xff73808c,14,status);cont();}\n\n\n### dxgfx.h\n#ifndef DXGFX_H\n#define DXGFX_H\n\n#ifdef __cplusplus\nextern \"C\" {\n#endif\n\n#ifdef DXGFX_BUILD\n#define DXGFX_API __declspec(dllexport)\n#else\n#define DXGFX_API __declspec(dllimport)\n#endif\n\ntypedef unsigned char dx_u8;\ntypedef unsigned int dx_u32;\n\nDXGFX_API int dxgfx_keyboard(dx_u8 out_state[256]);\nDXGFX_API int dxgfx_mouse(int out_state[4]);\nDXGFX_API int dxgfx_frame_begin(void);\nDXGFX_API int dxgfx_clear(dx_u32 argb);\nDXGFX_API int dxgfx_frame_end(void);\nDXGFX_API int dxgfx_screen_size(int out_size[2]);\nDXGFX_API int dxgfx_window_should_close(void);\nDXGFX_API int dxgfx_input_snapshot(dx_u8 keys_down[256], dx_u8 keys_pressed[256], dx_u8 keys_released[256], int mouse[8], char text[64]);\nDXGFX_API int dxgfx_set_camera(float target_x, float target_y, float zoom);\nDXGFX_API int dxgfx_world_mouse(float out_xy[2]);\nDXGFX_API int dxgfx_draw_text(int x, int y, dx_u32 argb, float size, const char *utf8, dx_u32 len);\nDXGFX_API int dxgfx_draw_rect(float x, float y, float w, float h, dx_u32 argb, float stroke, int fill);\nDXGFX_API int dxgfx_draw_line(float x1, float y1, float x2, float y2, dx_u32 argb, float stroke);\n\n#ifdef __cplusplus\n}\n#endif\n#endif\n\n\n### dxgfx.cpp\n247 extern \"C\" DXGFX_API int dxgfx_draw_text(int x, int y, dx_u32 argb, float size, const char *utf8, dx_u32 len) {\n260     HRESULT hr = g_dw->CreateTextFormat(L\"Consolas\", 0, DWRITE_FONT_WEIGHT_NORMAL,\n\n### build_mods.bat\n@echo off\n\nsetlocal enabledelayedexpansion\n\n\n\ncall build_cont.bat\n\ncall build_vmstack.bat\n\ncall build_vmvar.bat\n\ncall build_vmstore.bat\n\ncall build_vmexec.bat\n\ncall build_dxgfx.bat\n\ngcc -shared mods_src/add.c -o mods/add.dll libcont.a libvmstack.a libvmstate.a\n\ngcc -shared mods_src/ret.c -o mods/ret.dll libcont.a libvmstate.a\n\ngcc -shared mods_src/halt.c -o mods/halt.dll\n\ngcc -shared mods_src/sub.c -o mods/sub.dll libcont.a libvmstack.a libvmstate.a\n\ngcc -shared mods_src/mul.c -o mods/mul.dll libcont.a libvmstack.a libvmstate.a\n\ngcc -shared mods_src/div.c -o mods/div.dll libcont.a libvmstack.a libvmstate.a\n\ngcc -shared mods_src/mod.c -o mods/mod.dll libcont.a libvmstack.a libvmstate.a\n\ngcc -shared mods_src/eq.c -o mods/eq.dll libcont.a libvmstack.a libvmstate.a\n\ngcc -shared mods_src/neq.c -o mods/neq.dll libcont.a libvmstack.a libvmstate.a\n\ngcc -shared mods_src/gt.c -o mods/gt.dll libcont.a libvmstack.a libvmstate.a\n\ngcc -shared mods_src/lt.c -o mods/lt.dll libcont.a libvmstack.a libvmstate.a\n\ngcc -shared mods_src/gte.c -o mods/gte.dll libcont.a libvmstack.a libvmstate.a\n\ngcc -shared mods_src/lte.c -o mods/lte.dll libcont.a libvmstack.a libvmstate.a\n\ngcc -s