              "arguments": "{\"code\":\"from pathlib import Path\\nimport hashlib, subprocess, sys, os\\nroot = Path(r'C:\\\\Users\\\\12159\\\\Desktop\\\\Singularity')\\nos.chdir(root)\\n\\n# 1) Fix cond_payload: use cvm_exec, do not mutate live payload/program cache\\n(root/'mods_src'/'cond_payload.c').write_text(r'''typedef unsigned char u8;\\ntypedef unsigned u32;\\ntypedef u8 H[32];\\n\\nextern __declspec(dllimport) void cont(void);\\nextern __declspec(dllimport) void *pop(u32 size);\\nextern __declspec(dllimport) u8 *cvm_payload(void);\\nextern __declspec(dllimport) u32 cvm_payload_size(void);\\nextern __declspec(dllimport) void cvm_exec(const H h);\\n\\nstatic int mod_bool(const void *p) {\\n    const u8 *b = (const u8*)p;\\n    for (u32 i = 0; i < 4; i++) if (b[i]) return 1;\\n    return 0;\\n}\\n\\n/*\\n * payload: token[32]\\n * stack:   bool\\n *\\n * If true, exec token without rewriting the live instruction payload.\\n * (cvm_exec_payload mutates payload key->content hash and can corrupt the\\n * currently executing program block under reexec; that breaks later frames\\n * and can async-write a bad program override.)\\n */\\n__declspec(dllexport) void run(void) {\\n    H h;\\n    int ok = mod_bool(pop(4));\\n    u8 *p = cvm_payload();\\n    if (cvm_payload_size() < 32) { cont(); return; }\\n    for (u32 i = 0; i < 32; i++) h[i] = p[i];\\n    if (ok) cvm_exec(h);\\n    else cont();\\n}\\n''', encoding='utf-8')\\nprint('wrote cond_payload.c')\\n\\n# 2) Rebuild cond_payload dll + hash rename\\nsrc = root/'mods_src'/'cond_payload.c'\\nout = root/'mods'/'cond_payload.dll'\\ncmd = ['gcc','-shared',str(src),'-o',str(out),\\n       'libcont.a','libvmstack.a','libvmexec.a','libvmstate.a','libvmstore.a','libvm.a','-lws2_32']\\nr = subprocess.run(cmd, capture_output=True, text=True)\\nif r.returncode != 0:\\n    print(r.stdout); print(r.stderr); raise SystemExit('compile failed')\\ndata = out.read_bytes()\\nh = hashlib.sha256(data).hexdigest()\\nhashed = root/'mods'/f'{h}.dll'\\nif out.resolve() != hashed.resolve():\\n    if hashed.exists():\\n        out.unlink()\\n    else:\\n        out.replace(hashed)\\nprint('cond_payload ->', h)\\n\\n# 3) Pin token\\ntok_path = root/'atomic_mod_tokens.txt'\\nlines = tok_path.read_text(encoding='ascii').splitlines()\\nmp = {}\\norder = []\\nfor line in lines:\\n    if '=' not in line: continue\\n    n,v = line.split('=',1)\\n    if n not in mp: order.append(n)\\n    mp[n]=v\\nmp['cond_payload']=h\\nif 'cond_payload' not in order: order.append('cond_payload')\\ntok_path.write_text('\\\\n'.join(f'{n}={mp[n]}' for n in order if n in mp)+'\\\\n', encoding='ascii')\\nprint('pinned cond_payload')\\n\\n# 4) Also harden generator: on MMB/RMB press seed last mouse WITHOUT going through\\n# a separate cond that fires every idle frame too aggressively? Keep sample_mouse.\\n# But ensure pan works even if sample_mouse fails: seed inside pan on first use is hard.\\n# Optional: inline seed using mouse_button_pressed for mmb before pan - already there.\\n\\n# 5) Regenerate + install\\nr = subprocess.run([sys.executable, str(root/'generate_atomic_first_boot.py')], capture_output=True, text=True)\\nprint(r.stdout)\\nif r.returncode != 0:\\n    print(r.stderr); raise SystemExit('generate failed')\\nr = subprocess.run([sys.executable, str(root/'install_generic_first_boot.py')], capture_output=True, text=True)\\nprint(r.stdout)\\nprint(r.stderr)\\nif r.returncode != 0:\\n    raise SystemExit('install failed')\\n\\n# 6) Verify local program cache matches clean program (overwrite if dirty)\\nimport json\\nm=json.loads((root/'atomic_first_boot_manifest.json').read_text())\\nprog=m['program_hash']\\nclean=(root/'first_program_block.bin').read_bytes()\\nassert hashlib.sha256(clean).hexdigest()==prog\\ncache=root/'cache'/f'{prog}.bin'\\ncache.parent.mkdir(exist_ok=True)\\ncache.write_bytes(clean)\\nprint('refreshed local cache', prog)\\nprint('cond_payload native', m['native'].get('cond_payload'))\\nprint('program