i < t.count; i++) {\\n                if (t.views[i].used && same_key(t.views[i].key, key)) {\\n                    t.active = i;\\n                    t.dragging = (int)i;\\n                    t.views[i].x = x;\\n                    t.views[i].y = y;\\n                    out = i;\\n                    store(id, &t);\\n                    push(&out, 4);\\n                    cont();\\n                    return;\\n                }\\n            }'''\\nviews2 = (root/'mods_src'/'views.c').read_text(encoding='utf-8', errors='replace')\\nif old14 not in views2:\\n    raise SystemExit('views.c op14 patch target not found')\\n(root/'mods_src'/'views.c').write_text(views2.replace(old14, new14, 1), encoding='utf-8')\\nprint('patched views.c op14 regrab')\\n\\n# build_mods.bat add measure_text_var compile before hash rename\\nbm = (root/'build_mods.bat').read_text(encoding='utf-8', errors='replace')\\nmarker = 'gcc -shared mods_src/views_open_at_row.c -o mods/views_open_at_row.dll libcont.a libvmstack.a libvmvar.a libvmstate.a libvmstore.a libvm.a -lws2_32 -ladvapi32'\\ninsert = marker + '\\\\r\\\\n\\\\r\\\\ngcc -shared mods_src/measure_text_var.c -o mods/measure_text_var.dll libcont.a libvmstack.a libvmstate.a libvmvar.a libdxgfx.a'\\nif 'measure_text_var.c' not in bm:\\n    if marker not in bm:\\n        raise SystemExit('build_mods marker missing')\\n    bm = bm.replace(marker, insert, 1)\\n    (root/'build_mods.bat').write_text(bm, encoding='utf-8')\\n    print('patched build_mods.bat')\\nelse:\\n    print('build_mods already has measure_text_var')\"}"
