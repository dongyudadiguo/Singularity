\\n    print('views_open_at_row no match, current snippet:')\\n    i = vo.find('u8 key[32]')\\n    print(vo[i:i+250])\\n\\n# new mods\\n(root/'mods_src'/'mouse_f.c').write_text('''typedef unsigned u32;\\nextern __declspec(dllimport) void cont(void);\\nextern __declspec(dllimport) void push(const void *p, u32 size);\\n#include \\\"../dxgfx.h\\\"\\n/* push f32 mx, my client pixels */\\n__declspec(dllexport) void run(void) {\\n    float xy[2] = {0.0f, 0.0f};\\n    dxgfx_mouse_f(xy);\\n    push(xy, 8);\\n    cont();\\n}\\n''', encoding='utf-8')\\n\\n(root/'mods_src'/'drawtext_screen.c').write_text('''typedef unsigned char u8; typedef unsigned u32;\\nextern __declspec(dllimport) void cont(void);\\nextern __declspec(dllimport) u8 *cvm_payload(void);\\nextern __declspec(dllimport) u32 cvm_payload_size(void);\\n#include \\\"../dxgfx.h\\\"\\n/* payload: s32 x, s32 y, u32 ARGB, f32 size, text... (screen space) */\\n__declspec(dllexport) void run(void) {\\n    u8 *p = cvm_payload();\\n    u32 n = cvm_payload_size();\\n    if (n >= 16) {\\n        dxgfx_draw_text_screen(*(int*)p, *(int*)(p+4), *(u32*)(p+8), *(float*)(p+12),\\n                               (const char*)(p+16), n-16);\\n    }\\n    cont();\\n}\\n''', encoding='utf-8')\\n\\n(root/'mods_src'/'drawtext_xy_stack_screen.c').write_text('''typedef unsigned char u8; typedef unsigned u32;\\nextern __declspec(dllimport) void cont(void);\\nextern __declspec(dllimport) void *pop(u32);\\nextern __declspec(dllimport) u8 *cvm_payload(void);\\nextern __declspec(dllimport) u32 cvm_payload_size(void);\\n#include \\\"../dxgfx.h\\\"\\n/* stack: f32 x, f32 y, text[count]; payload: u32 ARGB, f32 size, u32 count */\\n__declspec(dllexport) void run(void) {\\n    u8 *p = cvm_payload();\\n    if (cvm_payload_size() >= 12) {\\n        u32 argb = *(u32*)p; float size = *(float*)(p+4); u32 count = *(u32*)(p+8);\\n        char *s = (char*)pop(count);\\n        float y = *(float*)pop(4);\\n        float x = *(float*)pop(4);\\n        dxgfx_draw_text_screen((int)x, (int)y, argb, size, s, count);\\n    }\\n    cont();\\n}\\n''', encoding='utf-8')\\n\\n(root/'mods_src'/'drawtext_var_xy_screen.c').write_text('''typedef unsigned char u8; typedef unsigned u32; typedef u8 H[32];\\nextern __declspec(dllimport) void cont(void);\\nextern __declspec(dllimport) void *pop(u32);\\nextern __declspec(dllimport) u8 *cvm_payload(void);\\nextern __declspec(dllimport) u32 cvm_payload_size(void);\\nextern __declspec(dllimport) u8 *cvm_var_get(const H, u32*);\\n#include \\\"../dxgfx.h\\\"\\n/* stack: f32 x, f32 y; payload: id[32], u32 ARGB, f32 size */\\n__declspec(dllexport) void run(void) {\\n    float y = *(float*)pop(4);\\n    float x = *(float*)pop(4);\\n    u8 *p = cvm_payload();\\n    if (cvm_payload_size() >= 40) {\\n        u32 n; u8 *s = cvm_var_get(p, &n);\\n        if (s) {\\n            u32 z = 0; while (z < n && s[z]) z++;\\n            dxgfx_draw_text_screen((int)x, (int)y, *(u32*)(p+32), *(float*)(p+36), (char*)s, z);\\n        }\\n    }\\n    cont();\\n}\\n''', encoding='utf-8')\\nprint('mods written')\"}"
