              "arguments": "{\"code\":\"from pathlib import Path\\nroot = Path(r'C:\\\\Users\\\\12159\\\\Desktop\\\\Singularity')\\n# Write measure_text_var.c\\nsrc = r'''#include <string.h>\\ntypedef unsigned char u8;\\ntypedef unsigned u32;\\ntypedef u8 H[32];\\nextern __declspec(dllimport) void cont(void);\\nextern __declspec(dllimport) void push(const void *p, u32 size);\\nextern __declspec(dllimport) u8 *cvm_payload(void);\\nextern __declspec(dllimport) u32 cvm_payload_size(void);\\nextern __declspec(dllimport) u8 *cvm_var_get(const H, u32 *);\\n#include \\\"../dxgfx.h\\\"\\n/* payload: id[32] + f32 size\\n * measures var C string width in layout units (pre-zoom).\\n * pushes f32 width.\\n */\\n__declspec(dllexport) void run(void) {\\n    float w = 0.0f;\\n    u8 *p = cvm_payload();\\n    u32 n = cvm_payload_size();\\n    if (n >= 36) {\\n        H id; memcpy(id, p, 32);\\n        float size = *(float *)(p + 32);\\n        u32 vn = 0;\\n        u8 *s = cvm_var_get(id, &vn);\\n        if (s && vn) {\\n            u32 z = 0;\\n            while (z < vn && s[z]) z++;\\n            float out[2] = {0.0f, 0.0f};\\n            if (z && dxgfx_measure_text(size, (const char *)s, z, out)) w = out[0];\\n        }\\n    }\\n    push(&w, 4);\\n    cont();\\n}\\n'''\\n(root/'mods_src'/'measure_text_var.c').write_text(src, encoding='utf-8')\\nprint('wrote measure_text_var.c')\\n\\n# Patch views.c op30 so reopening existing view also repositions under mouse (true drag-out regrab)\\nviews = (root/'mods_src'/'views.c').read_text(encoding='utf-8', errors='replace')\\nold = '''            if (found >= 0) {\\n                t.active = (u32)found;\\n                t.dragging = found;\\n            } else if (t.count < VIEW_MAX) {\\n                u32 ni = t.count++;\\n                zero_view(&t.views[ni]);\\n                t.views[ni].used = 1;\\n                memcpy(t.views[ni].key, key, 32);\\n                t.views[ni].x = mx;\\n                t.views[ni].y = my;\\n    