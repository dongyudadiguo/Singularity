 body not found, showing context')\\n        idx = text2.find('dxgfx_mouse(int')\\n        print(text2[idx:idx+400])\\n    else:\\n        text2 = text2.replace(old_mouse, new_mouse, 1)\\n    (root/'dxgfx.cpp').write_text(text2, encoding='utf-8')\\n    print('dxgfx order fixed')\\nelse:\\n    print('helper already before mouse')\\n\\n# verify compile-related includes - DPI_AWARENESS_CONTEXT needs windows 10 SDK; fallback without shellscalingapi\\ntext = (root/'dxgfx.cpp').read_text(encoding='utf-8')\\n# Avoid shellscalingapi dependency - use raw constants\\ntext = text.replace('#include <shellscalingapi.h>\\\\n', '')\\ntext = text.replace(\\n'''    HMODULE user32 = LoadLibraryA(\\\"user32.dll\\\");\\n    if (user32) {\\n        typedef BOOL (WINAPI *SetDpiAwarenessContext_t)(DPI_AWARENESS_CONTEXT);\\n        SetDpiAwarenessContext_t set_ctx = (SetDpiAwarenessContext_t)GetProcAddress(user32, \\\"SetProcessDpiAwarenessContext\\\");\\n        if (set_ctx) set_ctx(DPI_AWARENESS_CONTEXT_PER_MONITOR_AWARE_V2);\\n        else {\\n            typedef BOOL (WINAPI *SetProcessDPIAware_t)(void);\\n            SetProcessDPIAware_t set_aware = (SetProcessDPIAware_t)GetProcAddress(user32, \\\"SetProcessDPIAware\\\");\\n            if (set_aware) set_aware();\\n        }\\n    }\\n''',\\n'''    HMODULE user32 = LoadLibraryA(\\\"user32.dll\\\");\\n    if (user32) {\\n        typedef BOOL (WINAPI *SetDpiAwarenessContext_t)(void*);\\n        SetDpiAwarenessContext_t set_ctx = (SetDpiAwarenessContext_t)GetProcAddress(user32, \\\"SetProcessDpiAwarenessContext\\\");\\n        if (set_ctx) set_ctx((void*)(-4)); /* DPI_AWARENESS_CONTEXT_PER_MONITOR_AWARE_V2 */\\n        else {\\n            typedef BOOL (WINAPI *SetProcessDPIAware_t)(void);\\n            SetProcessDPIAware_t set_aware = (SetProcessDPIAware_t)GetProcAddress(user32, \\\"SetProcessDPIAware\\\");\\n            if (set_aware) set_aware();\\n        }\\n    }\\n'''\\n)\\n(root/'dxgfx.cpp').write_text(text, encoding='utf-8')\\nprint('dxgfx final patches ok')\\n# sanity: count mouse_in_rt defs\\nprint('defs', text.count('static void dxgfx_mouse_in_rt'))\\nprint('ExitProcess', 'ExitProcess' in text)\"}"
