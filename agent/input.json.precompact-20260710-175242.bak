            "function": {
              "name": "python",
              "arguments": "{\"code\":\"from pathlib import Path\\nimport hashlib, subprocess, sys, os, json, struct, re\\nroot = Path(r'C:\\\\Users\\\\12159\\\\Desktop\\\\Singularity')\\nos.chdir(root)\\n\\n# ========== 1) dxgfx: identity camera = screen pixels, pixel-perfect mouse ==========\\ndx = (root/'dxgfx.cpp').read_text(encoding='utf-8')\\n\\n# Replace mouse_in_rt to use client pixels only (no RT rescale). With DPI awareness,\\n# client pixels match physical pixels; D2D hwnd RT GetSize is in DIPs which may differ.\\nold_helper_start = 'static void dxgfx_mouse_in_rt(float *mx, float *my, float *cx, float *cy) {'\\nif old_helper_start not in dx:\\n    raise SystemExit('helper missing')\\n# replace whole helper function\\nm = re.search(r'static void dxgfx_mouse_in_rt\\\\(float \\\\*mx, float \\\\*my, float \\\\*cx, float \\\\*cy\\\\) \\\\{.*?\\\\n\\\\}', dx, re.S)\\nif not m:\\n    raise SystemExit('helper regex fail')\\nnew_helper = '''static void dxgfx_rt_size(float *rw, float *rh) {\\n    int csz[2] = {0, 0};\\n    RECT cr;\\n    if (g_hwnd && GetClientRect(g_hwnd, &cr)) {\\n        csz[0] = cr.right - cr.left;\\n        csz[1] = cr.bottom - cr.top;\\n    }\\n    /* Prefer client pixel size so mouse deltas and draw space match 1:1. */\\n    if (rw) *rw = (float)(csz[0] > 0 ? csz[0] : 1280);\\n    if (rh) *rh = (float)(csz[1] > 0 ? csz[1] : 720);\\n}\\n\\nstatic void dxgfx_mouse_in_rt(float *mx, float *my, float *cx, float *cy) {\\n    POINT p;\\n    GetCursorPos(&p);\\n    ScreenToClient(g_hwnd, &p);\\n    float rw, rh;\\n    dxgfx_rt_size(&rw, &rh);\\n    if (mx) *mx = (float)p.x;\\n    if (my) *my = (float)p.y;\\n    if (cx) *cx = rw * 0.5f;\\n    if (cy) *cy = rh * 0.5f;\\n}'''\\ndx = dx[:m.start()] + new_helper + dx[m.end():]\\n\\n# world_to_screen use client size\\ndx = re.sub(\\n    r'static void world_to_screen\\\\(float x, float y, float \\\\*sx, float \\\\*sy\\\\) \\\\{.*?\\\\n\\\\}',\\n    '''static void world_to_screen(float x, float y, float *sx, float *sy) {\\n    float rw, rh;\\n    dxgfx_rt_size(&rw, &rh);\\n    *sx = (x - g_cam_x) * g_zoom + rw * 0.5f;\\n    *sy = (y - g_cam_y) * g_zoom + rh * 0.5f;\\n}''',\\n    dx, count=1, flags=re.S)\\n\\n# Add screen-space draw helpers and mouse float API at end before last lines\\nif 'dxgfx_draw_text_screen' not in dx:\\n    dx = dx.rstrip() + '''\\n\\nextern \\\"C\\\" DXGFX_API int dxgfx_mouse_f(float out_xy[2]) {\\n    if (!out_xy || !dxgfx_init()) return 0;\\n    float mx, my, cx, cy;\\n    dxgfx_mouse_in_rt(&mx, &my, &cx, &cy);\\n    (void)cx; (void)cy;\\n    out_xy[0] = mx;\\n    out_xy[1] = my;\\n    return 1;\\n}\\n\\n/* Screen-space text: x,y are client pixels from top-left; ignore camera/zoom. */\\nextern \\\"C\\\" DXGFX_API int dxgfx_draw_text_screen(int x, int y, dx_u32 argb, float size, const char *utf8, dx_u32 len) {\\n    if (!utf8) return 0;\\n    if (size <= 0.0f) size = 20.0f;\\n    if (!dxgfx_auto_begin(argb)) return 0;\\n    int wlen = MultiByteToWideChar(CP_UTF8, 0, utf8, (int)len, 0, 0);\\n    if (wlen <= 0) return dxgfx_auto_end();\\n    wchar_t *ws = (wchar_t*)malloc((wlen + 1) * sizeof(wchar_t));\\n    if (!ws) return dxgfx_auto_end();\\n    MultiByteToWideChar(CP_UTF8, 0, utf8, (int)len, ws, wlen);\\n    ws[wlen] = 0;\\n    IDWriteTextFormat *fmt = 0;\\n    HRESULT hr = g_dw->CreateTextFormat(L\\\"Consolas\\\", 0, DWRITE_FONT_WEIGHT_NORMAL,\\n                                        DWRITE_FONT_STYLE_NORMAL, DWRITE_FONT_STRETCH_NORMAL,\\n                                        size, L\\\"\\\", &fmt);\\n    if (SUCCEEDED(hr)) {\\n        D2D1_SIZE_F s = g_rt->GetSize();\\n        float rw, rh; dxgfx_rt_size(&rw, &rh);\\n        /* map client pixels -> RT DIPs if they differ */\\n        float sx = (rw > 0.0f) ? (float)x * (s.width / rw) : (float)x;\\n        float sy = (rh > 0.0f) ? (float)y * (s.height / rh) : (float)y;\\n        D2D1_RECT_F r = D2D1::RectF(sx, sy, s.width, s.height);\\n        g_rt->DrawText(ws, (UINT32)wlen, fmt, r, g_brush, D2D1_DRAW_TEXT_OPTIONS_NONE, DWRITE_MEASURING_MODE_NATURAL);\\n        fmt->Release();\\n    }\\n    free(ws);\\n    return dxgfx_auto_end();\\n}\\n'''\\n\\n(root/'dxgfx.cpp').write_text(dx, encoding='utf-8')\\n\\n# header\\nh = (root/'dxgfx.h').read_text(encoding='utf-8')\\nif 'dxgfx_draw_text_screen' not in h:\\n    h = h.replace(\\n        'DXGFX_API int dxgfx_draw_text(int x, int y, dx_u32 argb, float size, const char *utf8, dx_u32 len);',\\n        'DXGFX_API int dxgfx_draw_text(int x, int y, dx_u32 argb, float size, const char *utf8, dx_u32 len);\\\\n'\\n        'DXGFX_API int dxgfx_draw_text_screen(int x, int y, dx_u32 argb, float size, const char *utf8, dx_u32 len);\\\\n'\\n        'DXGFX_API int dxgfx_mouse_f(float out_xy[2]);'\\n    )\\n    (root/'dxgfx.h').write_text(h, encoding='utf-8')\\n\\n# ========== 2) screen draw mods ==========\\n(root/'mods_src'/'drawtext_screen.c').write_text(r'''typedef unsigned char u8; typedef unsigned u32;\\nextern __declspec(dllimport) void cont(void);\\nextern __declspec(dllimport) u8 *cvm_payload(void);\\nextern __declspec(dllimport) u32 cvm_payload_size(void);\\n#include \\\"../dxgfx.h\\\"\\n/* payload: s32 x, s32 y, u32 ARGB, f32 size, text...  screen-space */\\n__declspec(dllexport) void run(void) {\\n    u8 *p = cvm_payload();\\n    u32 n = cvm_payload_size();\\n    if (n >= 16) {\\n        int x = *(int*)p, y = *(int*)(p+4);\\n        u32 c = *(u32*)(p+8); float s = *(float*)(p+12);\\n        const char *t = (const char*)(p+16);\\n        u32 len = n - 16;\\n        dxgfx_draw_text_screen(x, y, c, s, t, len);\\n    }\\n    cont();\\n}\\n''', encoding='utf-8')\\n\\n(root/'mods_src'/'drawtext_var_screen.c').write_text(r'''typedef unsigned char u8; typedef unsigned u32; typedef u8 H[32];\\nextern __declspec(dllimport) void cont(void);\\nextern __declspec(dllimport) u8 *cvm_payload(void);\\nextern __declspec(dllimport) u32 cvm_payload_size(void);\\nextern __declspec(dllimport) u8 *cvm_var_get(const H, u32*);\\n#include \\\"../dxgfx.h\\\"\\n/* payload: id[32], s32 x, s32 y, u32 ARGB, f32 size — screen-space */\\n__declspec(dllexport) void run(void) {\\n    u8 *p = cvm_payload();\\n    if (cvm_payload_size() >= 48) {\\n        u32 n; u8 *s = cvm_var_get(p, &n);\\n        if (s) {\\n            u32 z=0; while (z<n && s[z]) z++;\\n            dxgfx_draw_text_screen(*(int*)(p+32), *(int*)(p+36), *(u32*)(p+40), *(float*)(p+44), (char*)s, z);\\n        }\\n    }\\n    cont();\\n}\\n''', encoding='utf-8')\\n\\n(root/'mods_src'/'drawtext_xy_stack_screen.c').write_text(r'''typedef unsigned char u8; typedef unsigned u32;\\nextern __declspec(dllimport) void cont(void);\\nextern __declspec(dllimport) void *pop(u32);\\nextern __declspec(dllimport) u8 *cvm_payload(void);\\nextern __declspec(dllimport) u32 cvm_payload_size(void);\\n#include \\\"../dxgfx.h\\\"\\n/* stack: f32 x, f32 y, text[count]; payload: u32 ARGB, f32 size, u32 count — screen */\\n__declspec(dllexport) void run(void) {\\n    u8 *p = cvm_payload();\\n    if (cvm_payload_size() >= 12) {\\n        u32 argb = *(u32*)p; float size = *(float*)(p+4); u32 count = *(u32*)(p+8);\\n        char *s = (char*)pop(count);\\n        float y = *(float*)pop(4);\\n        float x = *(float*)pop(4);\\n        dxgfx_draw_text_screen((int)x, (int)y, argb, size, s, count);\\n    }\\n    cont();\\n}\\n''', encoding='utf-8')\\n\\n(root/'mods_src'/'mouse_f.c').write_text(r'''typedef unsigned u32;\\nextern __declspec(dllimport) void cont(void);\\nextern __declspec(dllimport) void push(const void *p, u32 size);\\n#include \\\"../dxgfx.h\\\"\\n/* push f32 mx, my in client pixels */\\n__declspec(dllexport) void run(void) {\\n    float xy[2] = {0,0};\\n    dxgfx_mouse_f(xy);\\n    push(xy, 8);\\n    cont();\\n}\\n''', encoding='utf-8')\\n\\n# ========== 3) views.c: open token OR payload-hash when payload is 32 bytes ==========\\nviews = (root/'mods_src'/'views.c').read_text(encoding='utf-8')\\n# Replace the key extraction in op30 after locating instruction at o\\nold_key = '''            u8 key[32];\\n            memset(key, 0, 32);\\n            if (o + 32 <= nlen && !zero_key(b + o)) memcpy(key, b + o, 32);\\n            if (zero_key(key)) break;'''\\nnew_key = '''            u8 key[32];\\n            memset(key, 0, 32);\\n            if (o + 32 <= nlen && !zero_key(b + o)) memcpy(key, b + o, 32);\\n            if (zero_key(key)) break;\\n            /* If instruction payload is exactly one hash[32], open THAT hash\\n             * (cond_payload / jump_payload / exec_payload style). Else open token. */\\n            if (o + 36 <= nlen) {\\n                u32 pn = *(u32 *)(b + o + 32);\\n                if (pn == 32 && o + 68 <= nlen) {\\n                    u8 ph[32];\\n                    memcpy(ph, b + o + 36, 32);\\n                    if (!zero_key(ph)) memcpy(key, ph, 32);\\n                }\\n            }'''\\nif old_key not in views:\\n    raise SystemExit('views key patch missing')\\nviews = views.replace(old_key, new_key, 1)\\n(root/'mods_src'/'views.c').write_text(views, encoding='utf-8')\\n\\n# also patch views_open_at_row similarly\\nvo = (root/'mods_src'/'views_open_at_row.c').read_text(encoding='utf-8')\\nold2 = '''    u8 key[32]; memset(key,0,32);\\n    if (o+32<=n && !zero32(b+o)) memcpy(key,b+o,32);\\n    if (zero32(key)) { push(&out,4); cont(); return; }'''\\nnew2 = '''    u8 key[32]; memset(key,0,32);\\n    if (o+32<=n && !zero32(b+o)) memcpy(key,b+o,32);\\n    if (zero32(key)) { push(&out,4); cont(); return; }\\n    if (o+36<=n) {\\n        u32 pn=*(u32*)(b+o+32);\\n        if (pn==32 && o+68<=n) {\\n            u8 ph[32]; memcpy(ph,b+o+36,32);\\n            if (!zero32(ph)) memcpy(key,ph,32);\\n        }\\n    }'''\\nif old2 in vo:\\n    (root/'mods_src'/'views_open_at_row.c').write_text(vo.replace(old2,new2,1), encoding='utf-8')\\n    print('patched views_open_at_row')\\nelse:\\n    print('views_open_at_row pattern skip')\\n\\n# ========== 4) build_mods entries ==========\\nbm = (root/'build_mods.bat').read_text(encoding='utf-8')\\nadds = [\\n    ('mods_src/drawtext_screen.c', 'gcc -shared mods_src/drawtext_screen.c -o mods/drawtext_screen.dll libcont.a libvmstate.a libdxgfx.a'),\\n    ('mods_src/drawtext_var_screen.c', 'gcc -shared mods_src/drawtext_var_screen.c -o mods/drawtext_var_screen.dll libcont.a libvmstate.a libvmvar.a libdxgfx.a'),\\n    ('mods_src/drawtext_xy_stack_screen.c', 'gcc -shared mods_src/drawtext_xy_stack_screen.c -o mods/drawtext_xy_stack_screen.dll libcont.a libvmstack.a libvmstate.a libdxgfx.a'),\\n    ('mods_src/mouse_f.c', 'gcc -shared mods_src/mouse_f.c -o mods/mouse_f.dll libcont.a libvmstack.a libvmstate.a libdxgfx.a'),\\n]\\nfor needle, line in adds:\\n    if needle not in bm:\\n        bm = bm.replace(\\n            'gcc -shared mods_src/views_open_at_row.c -o mods/views_open_at_row.dll libcont.a libvmstack.a libvmvar.a libvmstate.a libvmstore.a libvm.a -lws2_32 -ladvapi32',\\n            'gcc -shared mods_src/views_open_at_row.c -o mods/views_open_at_row.dll libcont.a libvmstack.a libvmvar.a libvmstate.a libvmstore.a libvm.a -lws2_32 -ladvapi32\\\\r\\\\n\\\\r\\\\n' + line\\n        )\\n(root/'build_mods.bat').write_text(bm, encoding='utf-8')\\n\\n# ========== 5) rebuild dxgfx + critical mods ==========\\nr = subprocess.run(['cmd','/c','build_dxgfx.bat'], capture_output=True, text=True)\\nprint('dxgfx', r.returncode, r.stderr[-500:] if r.stderr else r.stdout[-200:])\\nif r.returncode: raise SystemExit('dxgfx fail')\\n\\ndef build(src, outname, libs):\\n    out = root/'mods'/outname\\n    cmd = ['gcc','-shared',str(src),'-o',str(out)] + libs\\n    rr = subprocess.run(cmd, capture_output=True, text=True)\\n    if rr.returncode:\\n        print(rr.stdout); print(rr.stderr); raise SystemExit(f'fail {src}')\\n    data = out.read_bytes()\\n    hh = hashlib.sha256(data).hexdigest()\\n    hashed = root/'mods'/f'{hh}.dll'\\n    if out.resolve() != hashed.resolve():\\n        if hashed.exists(): out.unlink()\\n        else: out.replace(hashed)\\n    print(outname, '->', hh)\\n    return hh\\n\\nhashes = {}\\nhashes['views'] = build(root/'mods_src'/'views.c', 'views.dll',\\n    ['libcont.a','libvmstack.a','libvmvar.a','libvmstate.a','libvmstore.a','libvm.a','-lws2_32','-ladvapi32'])\\nhashes['views_open_at_row'] = build(root/'mods_src'/'views_open_at_row.c', 'views_open_at_row.dll',\\n    ['libcont.a','libvmstack.a','libvmvar.a','libvmstate.a','libvmstore.a','libvm.a','-lws2_32','-ladvapi32'])\\nhashes['drawtext_screen'] = build(root/'mods_src'/'drawtext_screen.c', 'drawtext_screen.dll',\\n    ['libcont.a','libvmstate.a','libdxgfx.a'])\\nhashes['drawtext_var_screen'] = build(root/'mods_src'/'drawtext_var_screen.c', 'drawtext_var_screen.dll',\\n    ['libcont.a','libvmstate.a','libvmvar.a','libdxgfx.a'])\\nhashes['drawtext_xy_stack_screen'] = build(root/'mods_src'/'drawtext_xy_stack_screen.c', 'drawtext_xy_stack_screen.dll',\\n    ['libcont.a','libvmstack.a','libvmstate.a','libdxgfx.a'])\\nhashes['mouse_f'] = build(root/'mods_src'/'mouse_f.c', 'mouse_f.dll',\\n    ['libcont.a','libvmstack.a','libvmstate.a','libdxgfx.a'])\\n# rebuild world_mouse against new dxgfx\\nhashes['world_mouse'] = build(root/'mods_src'/'world_mouse.c', 'world_mouse.dll',\\n    ['libcont.a','libvmstack.a','libvmstate.a','libdxgfx.a'])\\nhashes['mouse_x'] = build(root/'mods_src'/'mouse_x.c', 'mouse_x.dll',\\n    ['libcont.a','libvmstack.a','libvmstate.a','libdxgfx.a'])\\nhashes['mouse_y'] = build(root/'mods_src'/'mouse_y.c', 'mouse_y.dll',\\n    ['libcont.a','libvmstack.a','libvmstate.a','libdxgfx.a'])\\nhashes['measure_text_var'] = build(root/'mods_src'/'measure_text_var.c', 'measure_text_var.dll',\\n    ['libcont.a','libvmstack.a','libvmstate.a','libvmvar.a','libdxgfx.a'])\\n\\n# pin tokens\\ntok_path = root/'atomic_mod_tokens.txt'\\nmp={}; order=[]\\nfor line in tok_path.read_text(encoding='ascii').splitlines():\\n    if '=' not in line: continue\\n    n,v=line.split('=',1)\\n    if n not in mp: order.append(n)\\n    mp[n]=v\\nfor n,v in hashes.items():\\n    mp[n]=v\\n    if n not in order: order.append(n)\\ntok_path.write_text('\\\\n'.join(f'{n}={mp[n]}' for n in order if n in mp)+'\\\\n', encoding='ascii')\\nprint('tokens pinned')\\n\\n# ========== 6) generator: screen-delta pan/drag + screen HUD ==========\\ncontent = r'''import hashlib\\nimport json\\nimport struct\\nfrom pathlib import Path\\n\\nROOT = Path(__file__).resolve().parent\\nPROGRAM_KEY = hashlib.sha256(b\\\"#SingularityAtomicProgram\\\").digest()\\nINPUT_VAR = hashlib.sha256(b\\\"atomic.editor.input\\\").digest()\\nCAM_X = hashlib.sha256(b\\\"atomic.cam.x\\\").digest()\\nCAM_Y = hashlib.sha256(b\\\"atomic.cam.y\\\").digest()\\nCAM_Z = hashlib.sha256(b\\\"atomic.cam.z\\\").digest()\\nLAST_MX = hashlib.sha256(b\\\"atomic.cam.last_mx\\\").digest()\\nLAST_MY = hashlib.sha256(b\\\"atomic.cam.last_my\\\").digest()\\nVIEWS = hashlib.sha256(b\\\"atomic.views.table\\\").digest()\\n\\nACTION_CORE = (\\\"down\\\", \\\"up\\\", \\\"delete\\\", \\\"insert\\\", \\\"backspace\\\", \\\"clear\\\", \\\"save\\\")\\n\\n\\ndef load_tokens():\\n    result = {}\\n    raw = (ROOT / \\\"name_cache.bin\\\").read_bytes()\\n    count = struct.unpack_from(\\\"<I\\\", raw)[0]\\n    if len(raw) != 4 + count * 128:\\n        raise RuntimeError(\\\"invalid name_cache.bin\\\")\\n    for index in range(count):\\n        record = raw[4 + index * 128:4 + (index + 1) * 128]\\n        name = record[32:].split(b\\\"\\\\0\\\", 1)[0].decode(\\\"ascii\\\", \\\"ignore\\\")\\n        if name and name not in result and (ROOT / \\\"mods\\\" / f\\\"{record[:32].hex()}.dll\\\").exists():\\n            result[name] = record[:32]\\n    for line in (ROOT / \\\"atomic_mod_tokens.txt\\\").read_text(encoding=\\\"ascii\\\").splitlines():\\n        name, value = line.split(\\\"=\\\", 1)\\n        result[name] = bytes.fromhex(value)\\n    records = []\\n    for name, token in sorted(result.items()):\\n        encoded = name.encode(\\\"ascii\\\")[:95]\\n        records.append(token + encoded + bytes(96 - len(encoded)))\\n    (ROOT / \\\"instruction_names.bin\\\").write_bytes(struct.pack(\\\"<I\\\", len(records)) + b\\\"\\\".join(records))\\n    return result\\n\\n\\ndef instruction(token, payload=b\\\"\\\"):\\n    return token + struct.pack(\\\"<I\\\", len(payload)) + payload\\n\\n\\ndef make_block(items):\\n    return b\\\"\\\".join(instruction(*item) for item in items) + bytes(32)\\n\\n\\ndef u32(value):\\n    return struct.pack(\\\"<I\\\", value & 0xFFFFFFFF)\\n\\n\\ndef i32(value):\\n    return struct.pack(\\\"<i\\\", int(value))\\n\\n\\ndef f32(value):\\n    return struct.pack(\\\"<f\\\", float(value))\\n\\n\\ndef static_text(x, y, color, size, text):\\n    return struct.pack(\\\"<iiIf\\\", x, y, color, size) + text\\n\\n\\ndef var_text(var_id, x, y, color, size):\\n    return var_id + struct.pack(\\\"<iiIf\\\", x, y, color, size)\\n\\n\\ndef alloc_var(t, var_id, size):\\n    return (t[\\\"var_set_payload\\\"], var_id + u32(size))\\n\\n\\ndef views_op(t, op, args=b\\\"\\\"):\\n    return (t[\\\"views\\\"], VIEWS + u32(op) + args)\\n\\n\\ndef cond_action(t, key):\\n    return (t[\\\"cond_payload\\\"], key)\\n\\n\\ndef main():\\n    t = load_tokens()\\n    required = {\\n        \\\"frame_begin\\\", \\\"frame_clear\\\", \\\"frame_end\\\", \\\"reexec\\\", \\\"camera_set_stack\\\",\\n        \\\"drawtext_screen\\\", \\\"drawtext_var_screen\\\", \\\"drawtext_xy_stack_screen\\\",\\n        \\\"const_payload\\\", \\\"var_set_payload\\\", \\\"var_read_payload\\\", \\\"var_write_payload\\\",\\n        \\\"and\\\", \\\"key_down\\\", \\\"key_pressed\\\", \\\"cond_payload\\\", \\\"registry_find\\\",\\n        \\\"registry_token_name\\\", \\\"text_input\\\", \\\"string_append_var\\\", \\\"string_backspace_var\\\",\\n        \\\"string_clear_var\\\", \\\"block_insert_stack\\\", \\\"block_delete\\\", \\\"block_flush\\\",\\n        \\\"jump_payload\\\", \\\"mouse_f\\\", \\\"mouse_wheel\\\", \\\"mouse_button_down\\\", \\\"mouse_button_pressed\\\",\\n        \\\"i32_to_f32\\\", \\\"f32_add\\\", \\\"f32_sub\\\", \\\"f32_mul\\\", \\\"f32_const\\\", \\\"f32_clamp\\\",\\n        \\\"world_mouse\\\", \\\"drop_u32\\\", \\\"views\\\", \\\"views_render\\\", \\\"block_select_stack\\\",\\n        \\\"block_offset_at_index\\\", \\\"measure_text_var\\\", \\\"not\\\", \\\"screen_size\\\",\\n    }\\n    missing = sorted(required - t.keys())\\n    if missing:\\n        raise RuntimeError(f\\\"missing tokens: {', '.join(missing)}\\\")\\n\\n    action_keys = {name: hashlib.sha256((\\\"#atomic.action.\\\" + name).encode()).digest()\\n                   for name in ACTION_CORE}\\n    for name in (\\\"pan\\\", \\\"click\\\", \\\"rmb\\\", \\\"drag\\\", \\\"end_drag\\\"):\\n        action_keys[name] = hashlib.sha256((\\\"#atomic.action.\\\" + name).encode()).digest()\\n\\n    hit_args = f32(32.0) + f32(520.0) + f32(24.0) + u32(256)\\n\\n    # Pixel-space pan/drag: last_* are client pixel mouse samples.\\n    # cam' = cam - (mouse - last) / zoom  => content follows cursor 1:1.\\n    # view' = view + (mouse - last) / zoom\\n    pan = make_block([\\n        (t[\\\"var_read_payload\\\"], CAM_X),\\n        (t[\\\"mouse_f\\\"], b\\\"\\\"),                     # mx my  (drop my later)\\n        (t[\\\"drop_u32\\\"], b\\\"\\\"),                    # mx\\n        (t[\\\"var_read_payload\\\"], LAST_MX),\\n        (t[\\\"f32_sub\\\"], b\\\"\\\"),\\n        (t[\\\"var_read_payload\\\"], CAM_Z),\\n        (t[\\\"f32_div\\\"], b\\\"\\\"),\\n        (t[\\\"f32_sub\\\"], b\\\"\\\"),\\n        (t[\\\"var_write_payload\\\"], CAM_X),\\n        (t[\\\"var_read_payload\\\"], CAM_Y),\\n        (t[\\\"mouse_f\\\"], b\\\"\\\"),                     # mx my\\n        (t[\\\"swap_u32\\\"], b\\\"\\\"),                    # my mx\\n        (t[\\\"drop_u32\\\"], b\\\"\\\"),                    # my\\n        (t[\\\"var_read_payload\\\"], LAST_MY),\\n        (t[\\\"f32_sub\\\"], b\\\"\\\"),\\n        (t[\\\"var_read_payload\\\"], CAM_Z),\\n        (t[\\\"f32_div\\\"], b\\\"\\\"),\\n        (t[\\\"f32_sub\\\"], b\\\"\\\"),\\n        (t[\\\"var_write_payload\\\"], CAM_Y),\\n    ])\\n\\n    # Need swap_u32\\n    if \\\"swap_u32\\\" not in t:\\n        raise RuntimeError(\\\"missing swap_u32\\\")\\n\\n    drag = make_block([\\n        # push dx, dy for views op12 (pops dy then dx)\\n        (t[\\\"mouse_f\\\"], b\\\"\\\"),                     # mx my\\n        (t[\\\"drop_u32\\\"], b\\\"\\\"),                    # mx\\n        (t[\\\"var_read_payload\\\"], LAST_MX),\\n        (t[\\\"f32_sub\\\"], b\\\"\\\"),\\n        (t[\\\"var_read_payload\\\"], CAM_Z),\\n        (t[\\\"f32_div\\\"], b\\\"\\\"),                     # dx\\n        (t[\\\"mouse_f\\\"], b\\\"\\\"),                     # dx mx my\\n        (t[\\\"swap_u32\\\"], b\\\"\\\"),                    # dx my mx\\n        (t[\\\"drop_u32\\\"], b\\\"\\\"),                    # dx my\\n        (t[\\\"var_read_payload\\\"], LAST_MY),\\n        (t[\\\"f32_sub\\\"], b\\\"\\\"),\\n        (t[\\\"var_read_payload\\\"], CAM_Z),\\n        (t[\\\"f32_div\\\"], b\\\"\\\"),                     # dx dy\\n        views_op(t, 12),\\n    ])\\n\\n    end_drag = make_block([views_op(t, 13)])\\n\\n    click = make_block([\\n        (t[\\\"world_mouse\\\"], b\\\"\\\"),\\n        views_op(t, 29, hit_args),\\n        (t[\\\"drop_u32\\\"], b\\\"\\\"),\\n    ])\\n\\n    rmb = make_block([\\n        (t[\\\"world_mouse\\\"], b\\\"\\\"),\\n        views_op(t, 30, hit_args),  # opens payload hash when pn==32\\n        (t[\\\"drop_u32\\\"], b\\\"\\\"),\\n    ])\\n\\n    def select_active_block():\\n        return [views_op(t, 22), (t[\\\"block_select_stack\\\"], b\\\"\\\")]\\n\\n    def active_cursor_to_offset():\\n        return [views_op(t, 21), (t[\\\"block_offset_at_index\\\"], b\\\"\\\")]\\n\\n    actions = {\\n        \\\"down\\\": make_block([views_op(t, 23, i32(1))]),\\n        \\\"up\\\": make_block([views_op(t, 24)]),\\n        \\\"delete\\\": make_block(\\n            select_active_block() + active_cursor_to_offset() + [\\n                (t[\\\"block_delete\\\"], b\\\"\\\"),\\n                (t[\\\"jump_payload\\\"], PROGRAM_KEY),\\n            ]\\n        ),\\n        \\\"insert\\\": make_block(\\n            select_active_block() + active_cursor_to_offset() + [\\n                (t[\\\"var_read_payload\\\"], INPUT_VAR),\\n                (t[\\\"registry_find\\\"], b\\\"\\\"),\\n                (t[\\\"block_insert_stack\\\"], b\\\"\\\"),\\n                (t[\\\"string_clear_var\\\"], INPUT_VAR),\\n                (t[\\\"jump_payload\\\"], PROGRAM_KEY),\\n            ]\\n        ),\\n        \\\"backspace\\\": make_block([(t[\\\"string_backspace_var\\\"], INPUT_VAR)]),\\n        \\\"clear\\\": make_block([(t[\\\"string_clear_var\\\"], INPUT_VAR)]),\\n        \\\"save\\\": make_block(select_active_block() + [(t[\\\"block_flush\\\"], b\\\"\\\")]),\\n        \\\"pan\\\": pan,\\n        \\\"click\\\": click,\\n        \\\"rmb\\\": rmb,\\n        \\\"drag\\\": drag,\\n        \\\"end_drag\\\": end_drag,\\n    }\\n\\n    program = [\\n        (t[\\\"frame_begin\\\"], b\\\"\\\"),\\n        views_op(t, 18, PROGRAM_KEY + f32(40.0) + f32(70.0)),\\n        (t[\\\"var_read_payload\\\"], CAM_X),\\n        (t[\\\"var_read_payload\\\"], CAM_Y),\\n        (t[\\\"var_read_payload\\\"], CAM_Z),\\n        (t[\\\"camera_set_stack\\\"], b\\\"\\\"),\\n        (t[\\\"frame_clear\\\"], u32(0xff11161b)),\\n\\n        (t[\\\"mouse_button_pressed\\\"], u32(1)),\\n        cond_action(t, action_keys[\\\"click\\\"]),\\n        (t[\\\"mouse_button_pressed\\\"], u32(2)),\\n        cond_action(t, action_keys[\\\"rmb\\\"]),\\n\\n        (t[\\\"mouse_button_down\\\"], u32(4)),\\n        cond_action(t, action_keys[\\\"pan\\\"]),\\n        (t[\\\"mouse_button_down\\\"], u32(2)),\\n        cond_action(t, action_keys[\\\"drag\\\"]),\\n        (t[\\\"mouse_button_down\\\"], u32(2)),\\n        (t[\\\"not\\\"], b\\\"\\\"),\\n        cond_action(t, action_keys[\\\"end_drag\\\"]),\\n\\n        (t[\\\"var_read_payload\\\"], CAM_Z),\\n        (t[\\\"mouse_wheel\\\"], b\\\"\\\"), (t[\\\"i32_to_f32\\\"], b\\\"\\\"),\\n        (t[\\\"f32_const\\\"], f32(0.1)), (t[\\\"f32_mul\\\"], b\\\"\\\"),\\n        (t[\\\"f32_const\\\"], f32(1.0)), (t[\\\"f32_add\\\"], b\\\"\\\"),\\n        (t[\\\"f32_mul\\\"], b\\\"\\\"),\\n        (t[\\\"f32_clamp\\\"], f32(0.15) + f32(6.0)),\\n        (t[\\\"var_write_payload\\\"], CAM_Z),\\n\\n        (t[\\\"var_read_payload\\\"], CAM_X),\\n        (t[\\\"var_read_payload\\\"], CAM_Y),\\n        (t[\\\"var_read_payload\\\"], CAM_Z),\\n        (t[\\\"camera_set_stack\\\"], b\\\"\\\"),\\n\\n        # end-frame pixel mouse sample\\n        (t[\\\"mouse_f\\\"], b\\\"\\\"),\\n        (t[\\\"var_write_payload\\\"], LAST_MY),\\n        (t[\\\"var_write_payload\\\"], LAST_MX),\\n\\n        (t[\\\"views_render\\\"], VIEWS),\\n\\n        # HUD in true screen space (top-left / bottom-left, follows window size)\\n        (t[\\\"drawtext_screen\\\"], static_text(20, 16, 0xff9da7b3, 16.0,\\n            b\\\"multi-view  |  wheel zoom  MMB pan  LMB select  RMB open/drag (payload hash)  Ctrl+S\\\")),\\n        (t[\\\"text_input\\\"], b\\\"\\\"), (t[\\\"string_append_var\\\"], INPUT_VAR),\\n        # y = height - 52\\n        (t[\\\"screen_size\\\"], b\\\"\\\"),                 # w h\\n        (t[\\\"drop_u32\\\"], b\\\"\\\"),                    # h  (drop w - wait screen_size pushes w then h? check)\\n    ]\\n\\n    # screen_size pushes int[2] = w,h as 8 bytes. push order: push(s,8) so low addr w then h.\\n    # stack grows: first w then h on top? push copies bytes in order; pop takes from end.\\n    # push(s,8): if stack was empty, memory is w(4)+h(4), sp=8; pop(4) gets h first.\\n    # So top is h, under is w. Good: drop w? We need h only for bottom HUD.\\n    # Actually after push(s,8), pop(4)=h, pop(4)=w.\\n\\n    # Rebuild HUD section carefully\\n    program = program[:-4]  # remove incomplete HUD\\n    program += [\\n        (t[\\\"drawtext_screen\\\"], static_text(20, 16, 0xff9da7b3, 16.0,\\n            b\\\"multi-view  |  wheel zoom  MMB pan  LMB select  RMB open payload-hash  Ctrl+S\\\")),\\n        (t[\\\"text_input\\\"], b\\\"\\\"), (t[\\\"string_append_var\\\"], INPUT_VAR),\\n        # bottom-left input: y = screen_h - 52\\n        (t[\\\"screen_size\\\"], b\\\"\\\"),                 # ... w h(top)\\n        (t[\\\"i32_to_f32\\\"], b\\\"\\\"),                  # ... w h_f\\n        (t[\\\"f32_const\\\"], f32(52.0)),\\n        (t[\\\"f32_sub\\\"], b\\\"\\\"),                     # ... w y\\n        (t[\\\"swap_u32\\\"], b\\\"\\\"),                    # ... y w\\n        (t[\\\"drop_u32\\\"], b\\\"\\\"),                    # ... y\\n        (t[\\\"f32_const\\\"], f32(20.0)),             # ... y x\\n        (t[\\\"swap_u32\\\"], b\\\"\\\"),                    # ... x y\\n        # drawtext_var_screen needs fixed payload coords - use xy stack screen for input? \\n        # simpler: use drawtext_var_screen with dynamic - need stack version.\\n        # Use: measure path with drawtext_xy_stack_screen for both? input is var.\\n        # Keep drawtext_var_screen at computed position via writing temp? \\n        # Easiest fixed approach: draw input with drawtext_var_screen only after we have x,y on stack - not supported.\\n        # So use registry of: const 20, screen_h-52 in payload by recomputing each frame with stack text for match only.\\n        # For input var, add drawtext_var_xy_stack_screen? quick: hardcode using screen_size in a small action.\\n    ]\\n\\n    # Simpler HUD: keep top-left screen text; bottom uses screen_h each frame via stack drawing of input through a helper action.\\n    # Implement inline: pop y; we need draw var at (20,y). Create native already? Use measure + stack for match;\\n    # for input string, read var to stack isn't free. drawtext_var_screen with payload x,y fixed fails resize.\\n    # Add drawtext_var_xy_stack_screen: stack x,y; payload id,color,size\\n\\n    raise SystemExit('rewrite generator cleanly below')\\n\\n\\nif __name__ == '__main__':\\n    main()\\n'''\\n# Write clean generator without the incomplete raise\\ncontent = r'''import hashlib\\nimport json\\nimport struct\\nfrom pathlib import Path\\n\\nROOT = Path(__file__).resolve().parent\\nPROGRAM_KEY = hashlib.sha256(b\\\"#SingularityAtomicProgram\\\").digest()\\nINPUT_VAR = hashlib.sha256(b\\\"atomic.editor.input\\\").digest()\\nCAM_X = hashlib.sha256(b\\\"atomic.cam.x\\\").digest()\\nCAM_Y = hashlib.sha256(b\\\"atomic.cam.y\\\").digest()\\nCAM_Z = hashlib.sha256(b\\\"atomic.cam.z\\\").digest()\\nLAST_MX = hashlib.sha256(b\\\"atomic.cam.last_mx\\\").digest()\\nLAST_MY = hashlib.sha256(b\\\"atomic.cam.last_my\\\").digest()\\nVIEWS = hashlib.sha256(b\\\"atomic.views.table\\\").digest()\\n\\nACTION_CORE = (\\\"down\\\", \\\"up\\\", \\\"delete\\\", \\\"insert\\\", \\\"backspace\\\", \\\"clear\\\", \\\"save\\\")\\n\\n\\ndef load_tokens():\\n    result = {}\\n    raw = (ROOT / \\\"name_cache.bin\\\").read_bytes()\\n    count = struct.unpack_from(\\\"<I\\\", raw)[0]\\n    if len(raw) != 4 + count * 128:\\n        raise RuntimeError(\\\"invalid name_cache.bin\\\")\\n    for index in range(count):\\n        record = raw[4 + index * 128:4 + (index + 1) * 128]\\n        name = record[32:].split(b\\\"\\\\0\\\", 1)[0].decode(\\\"ascii\\\", \\\"ignore\\\")\\n        if name and name not in result and (ROOT / \\\"mods\\\" / f\\\"{record[:32].hex()}.dll\\\").exists():\\n            result[name] = record[:32]\\n    for line in (ROOT / \\\"atomic_mod_tokens.txt\\\").read_text(encoding=\\\"ascii\\\").splitlines():\\n        name, value = line.split(\\\"=\\\", 1)\\n        result[name] = bytes.fromhex(value)\\n    records = []\\n    for name, token in sorted(result.items()):\\n        encoded = name.encode(\\\"ascii\\\")[:95]\\n        records.append(token + encoded + bytes(96 - len(encoded)))\\n    (ROOT / \\\"instruction_names.bin\\\").write_bytes(struct.pack(\\\"<I\\\", len(records)) + b\\\"\\\".join(records))\\n    return result\\n\\n\\ndef instruction(token, payload=b\\\"\\\"):\\n    return token + struct.pack(\\\"<I\\\", len(payload)) + payload\\n\\n\\ndef make_block(items):\\n    return b\\\"\\\".join(instruction(*item) for item in items) + bytes(32)\\n\\n\\ndef u32(value):\\n    return struct.pack(\\\"<I\\\", value & 0xFFFFFFFF)\\n\\n\\ndef i32(value):\\n    return struct.pack(\\\"<i\\\", int(value))\\n\\n\\ndef f32(value):\\n    return struct.pack(\\\"<f\\\", float(value))\\n\\n\\ndef static_text(x, y, color, size, text):\\n    return struct.pack(\\\"<iiIf\\\", x, y, color, size) + text\\n\\n\\ndef var_text(var_id, x, y, color, size):\\n    return var_id + struct.pack(\\\"<iiIf\\\", x, y, color, size)\\n\\n\\ndef alloc_var(t, var_id, size):\\n    return (t[\\\"var_set_payload\\\"], var_id + u32(size))\\n\\n\\ndef views_op(t, op, args=b\\\"\\\"):\\n    return (t[\\\"views\\\"], VIEWS + u32(op) + args)\\n\\n\\ndef cond_action(t, key):\\n    return (t[\\\"cond_payload\\\"], key)\\n\\n\\ndef main():\\n    t = load_tokens()\\n    required = {\\n        \\\"frame_begin\\\", \\\"frame_clear\\\", \\\"frame_end\\\", \\\"reexec\\\", \\\"camera_set_stack\\\",\\n        \\\"drawtext_screen\\\", \\\"drawtext_var_xy_screen\\\", \\\"drawtext_xy_stack_screen\\\",\\n        \\\"const_payload\\\", \\\"var_set_payload\\\", \\\"var_read_payload\\\", \\\"var_write_payload\\\",\\n        \\\"and\\\", \\\"key_down\\\", \\\"key_pressed\\\", \\\"cond_payload\\\", \\\"registry_find\\\",\\n        \\\"registry_token_name\\\", \\\"text_input\\\", \\\"string_append_var\\\", \\\"string_backspace_var\\\",\\n        \\\"string_clear_var\\\", \\\"block_insert_stack\\\", \\\"block_delete\\\", \\\"block_flush\\\",\\n        \\\"jump_payload\\\", \\\"mouse_f\\\", \\\"mouse_wheel\\\", \\\"mouse_button_down\\\", \\\"mouse_button_pressed\\\",\\n        \\\"i32_to_f32\\\", \\\"f32_add\\\", \\\"f32_sub\\\", \\\"f32_mul\\\", \\\"f32_const\\\", \\\"f32_clamp\\\",\\n        \\\"world_mouse\\\", \\\"drop_u32\\\", \\\"swap_u32\\\", \\\"views\\\", \\\"views_render\\\", \\\"block_select_stack\\\",\\n        \\\"block_offset_at_index\\\", \\\"measure_text_var\\\", \\\"not\\\", \\\"screen_size\\\", \\\"dup_u32\\\",\\n    }\\n    missing = sorted(required - t.keys())\\n    if missing:\\n        raise RuntimeError(f\\\"missing tokens: {', '.join(missing)}\\\")\\n\\n    action_keys = {name: hashlib.sha256((\\\"#atomic.action.\\\" + name).encode()).digest()\\n                   for name in ACTION_CORE}\\n    for name in (\\\"pan\\\", \\\"click\\\", \\\"rmb\\\", \\\"drag\\\", \\\"end_drag\\\"):\\n        action_keys[name] = hashlib.sha256((\\\"#atomic.action.\\\" + name).encode()).digest()\\n\\n    hit_args = f32(32.0) + f32(520.0) + f32(24.0) + u32(256)\\n\\n    # Client-pixel pan/drag. last_* sampled end of previous frame.\\n    # cam moves opposite mouse/zoom so grabbed world point stays under cursor.\\n    pan = make_block([\\n        (t[\\\"var_read_payload\\\"], CAM_X),\\n        (t[\\\"mouse_f\\\"], b\\\"\\\"), (t[\\\"drop_u32\\\"], b\\\"\\\"),\\n        (t[\\\"var_read_payload\\\"], LAST_MX), (t[\\\"f32_sub\\\"], b\\\"\\\"),\\n        (t[\\\"var_read_payload\\\"], CAM_Z), (t[\\\"f32_div\\\"], b\\\"\\\"),\\n        (t[\\\"f32_sub\\\"], b\\\"\\\"),\\n        (t[\\\"var_write_payload\\\"], CAM_X),\\n        (t[\\\"var_read_payload\\\"], CAM_Y),\\n        (t[\\\"mouse_f\\\"], b\\\"\\\"), (t[\\\"swap_u32\\\"], b\\\"\\\"), (t[\\\"drop_u32\\\"], b\\\"\\\"),\\n        (t[\\\"var_read_payload\\\"], LAST_MY), (t[\\\"f32_sub\\\"], b\\\"\\\"),\\n        (t[\\\"var_read_payload\\\"], CAM_Z), (t[\\\"f32_div\\\"], b\\\"\\\"),\\n        (t[\\\"f32_sub\\\"], b\\\"\\\"),\\n        (t[\\\"var_write_payload\\\"], CAM_Y),\\n    ])\\n\\n    drag = make_block([\\n        (t[\\\"mouse_f\\\"], b\\\"\\\"), (t[\\\"drop_u32\\\"], b\\\"\\\"),\\n        (t[\\\"var_read_payload\\\"], LAST_MX), (t[\\\"f32_sub\\\"], b\\\"\\\"),\\n        (t[\\\"var_read_payload\\\"], CAM_