W_SHOW);\\\\n    dxgfx_pump();',\\n        'dxgfx_pump();\\\\n    if (g_close) ExitProcess(0);\\\\n    if (!IsWindowVisible(g_hwnd) && !g_close) ShowWindow(g_hwnd, SW_SHOW);'\\n    )\\n    # also frame_begin style\\n    if 'ExitProcess(0)' not in dx:\\n        dx = dx.replace(\\n'''extern \\\"C\\\" DXGFX_API int dxgfx_frame_begin(void) {\\n    if (!dxgfx_init()) return 0;\\n    if (!IsWindowVisible(g_hwnd) && !g_close) ShowWindow(g_hwnd, SW_SHOW);\\n    dxgfx_pump();\\n    dxgfx_resize_target();\\n''',\\n'''extern \\\"C\\\" DXGFX_API int dxgfx_frame_begin(void) {\\n    if (!dxgfx_init()) return 0;\\n    dxgfx_pump();\\n    if (g_close) ExitProcess(0);\\n    if (!IsWindowVisible(g_hwnd) && !g_close) ShowWindow(g_hwnd, SW_SHOW);\\n    dxgfx_resize_target();\\n''')\\nprint('exit on close', 'ExitProcess(0)' in dx)\\n\\nif 'WM_CLOSE) { g_close = 1; ShowWindow' in dx:\\n    dx = dx.replace(\\n        'if (m == WM_CLOSE) { g_close = 1; ShowWindow(h, SW_HIDE); return 0; }',\\n        'if (m == WM_CLOSE) { g_close = 1; DestroyWindow(h); return 0; }'\\n    )\\nprint('wm_close destroy', 'DestroyWindow(h)' in dx)\\n\\n# append screen APIs if missing\\nif 'dxgfx_draw_text_screen' not in dx:\\n    dx = dx.rstrip() + '''\\n\\nextern \\\"C\\\" DXGFX_API int dxgfx_mouse_f(float out_xy[2]) {\\n    if (!out_xy || !dxgfx_init()) return 0;\\n    float mx, my, cx, cy;\\n    dxgfx_mouse_in_rt(&mx, &my, &cx, &cy);\\n    (void)cx; (void)cy;\\n    out_xy[0] = mx;\\n    out_xy[1] = my;\\n    return 1;\\n}\\n\\nextern \\\"C\\\" DXGFX_API int dxgfx_draw_text_screen(int x, int y, dx_u32 argb, float size, const char *utf8, dx_u32 len) {\\n    if (!utf8) return 0;\\n    if (size <= 0.0f) size = 20.0f;\\n    if (!dxgfx_auto_begin(argb)) return 0;\\n    int wlen = MultiByteToWideChar(CP_UTF8, 0, utf8, (int)len, 0, 0);\\n    if (wlen <= 0) return dxgfx_auto_end();\\n    wchar_t *ws = (wchar_t*)malloc((wlen + 1) * sizeof(wchar_t));\\n    if (!ws) return dxgfx_auto_end();\\n    MultiByteToWideChar(CP_UTF8, 0, utf8, (int)len, ws, wlen);\\n    ws[wlen] = 0;\\n    IDWriteTextFormat *fmt = 0;\\n    HRESULT hr = g_dw->CreateTextFormat(L\\\"Consolas\\\", 0, DWRITE_FONT_WEIGHT_NORMAL,\\n                                        DWRITE_FONT_STYLE_NORMAL, DWRITE_FONT_STRETCH_NORMAL,\\n                                        size, L\\\"\\\", &fmt);\\n    if (SUCCEEDED(hr)) {\\n        D2D1_SIZE_F s = g_rt->GetSize();\\n        float rw, rh; dxgfx_rt_size(&rw, &rh);\\n        float sx = (rw > 0.0f) ? (float)x * (s.width / rw) : (float)x;\\n        float sy = (rh > 0.0f) ? (float)y * (s.height / rh) : (float)y;\\n        D2D1_RECT_F r = D2D1::RectF(sx, sy, s.width, s.height);\\n        g_rt->DrawText(ws, (UINT32)wlen, fmt, r, g_brush, D2D1_DRAW_TEXT_OPTIONS_NONE, DWRITE_MEASURING_MODE_NATURAL);\\n        fmt->Release();\\n    }\\n    free(ws);\\n    return dxgfx_auto_end();\\n}\\n'''\\n    print('appended screen APIs')\\n\\ndx_path.write_text(dx, encoding='utf-8')\\nprint('dxgfx.cpp written', dx_path.stat().st_size)\\n\\n# header\\nh_path = root/'dxgfx.h'\\nh = h_path.read_text(encoding='utf-8')\\nif 'dxgfx_draw_text_screen' not in h:\\n    h = h.replace(\\n        'DXGFX_API int dxgfx_draw_text(int x, int y, dx_u32 argb, float size, const char *utf8, dx_u32 len);',\\n        'DXGFX_API int dxgfx_draw_text(int x, int y, dx_u32 argb, float size, const char *utf8, dx_u32 len);\\\\n'\\n        'DXGFX_API int dxgfx_draw_text_screen(int x, int y, dx_u32 argb, float size, const char *utf8, dx_u32 len);\\\\n'\\n        'DXGFX_API int dxgfx_mouse_f(float out_xy[2]);'\\n    )\\n    h_path.write_text(h, encoding='utf-8')\\n    print('dxgfx.h updated')\\nelse:\\n    print('dxgfx.h already ok')\"}"
