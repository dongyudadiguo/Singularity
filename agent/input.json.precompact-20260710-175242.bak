        "content": "typedef unsigned char u8;\ntypedef unsigned u32;\ntypedef u8 H[32];\n\nextern __declspec(dllimport) void cont(void);\nextern __declspec(dllimport) void *pop(u32 size);\nextern __declspec(dllimport) void cvm_exec(const H h);\n\nstatic int mod_bool(const void *p) {\n    const u8 *b = (const u8*)p;\n    for (u32 i = 0; i < 4; i++) if (b[i]) return 1;\n    return 0;\n}\n\n__declspec(dllexport) void run(void) {\n    H h;\n    int ok = mod_bool(pop(4));\n    u8 *p = pop(32);\n    for (u32 i = 0; i < 32; i++) h[i] = p[i];\n    if (ok) cvm_exec(h);\n    else cont();\n}\n\n---\ntypedef unsigned char u8;\ntypedef unsigned u32;\ntypedef u8 H[32];\n\nextern __declspec(dllimport) void cont(void);\nextern __declspec(dllimport) void *pop(u32 size);\nextern __declspec(dllimport) void cvm_exec(const H h);\n\nstatic int zero32(const u8 *p) {\n    for (int i = 0; i < 32; i++) if (p[i]) return 0;\n    return 1;\n}\n\n/* Unconditional exec of a stack token.\n * Target may be native (DLL) or a logical/content block key; VM decides.\n * Stack: ... token[32] -> ...\n */\n__declspec(dllexport) void run(void) {\n    H h;\n    u8 *p = (u8*)pop(32);\n    for (u32 i = 0; i < 32; i++) h[i] = p[i];\n    if (zero32(h)) { cont(); return; }\n    cvm_exec(h);\n}\n\nCACHE slots thrashing could cause wrong block content while executing program\nlocal program size 4082 sha f440f9cf898477c81278a376703f476345ce9d8ba2d740d0a8dd47d2cbf7f2f6\ncache exists True\ncache size 4082 sha f440f9cf898477c81278a376703f476345ce9d8ba2d740d0a8dd47d2cbf7f2f6\ncond_payload key 4634cc1ea67c8ad2 is_action_key True click is_action_hash False None\ncond_payload key 102da1e22a6b6818 is_action_key True rmb is_action_hash False None\ncond_payload key d7a0c0d2326c678c is_action_key True sample_mouse is_action_hash False None\ncond_payload key 1a639119bc8f4c00 is_action_key True pan is_action_hash False None\ncond_payload key 4b17485042a26f0d is_action_key True drag is_action_hash False None\ncond_payload key 92